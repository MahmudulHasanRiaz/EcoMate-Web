{
  "name": "ecomate",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "admin:dev": "npm run dev --workspace=admin",
    "storefront:dev": "npm run dev --workspace=storefront",
    "backend:dev": "npm run start:dev --workspace=backend",
    "dev": "concurrently \"npm run admin:dev\" \"npm run storefront:dev\" \"npm run backend:dev\"",
    "storefront:build": "npm run build --workspace=storefront",
    "storefront:start": "npm run start --workspace=storefront",
    "install:all": "npm install"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
