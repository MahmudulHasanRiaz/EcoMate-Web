# ==========================================
# ECOMATE WEB - PORTAINER STACK ENVIRONMENT
# ==========================================

# 1. Client Details & Domain (REQUIRED)
# Replace this with the actual domain for the client (e.g., client-name.com)
CLIENT_DOMAIN=mac.riaz.com.bd

# 2. Port Configuration (Change if running multiple clients on one server)
HTTP_PORT=80
HTTPS_PORT=443
TRAEFIK_ACME_EMAIL=admin@example.com
BACKEND_PORT=4000
STOREFRONT_PORT=3000
ADMIN_PORT=8080

# 3. Security Secrets (REQUIRED - MUST CHANGE IN PRODUCTION)
# Use a strong random string (e.g., generate using `openssl rand -hex 32` or a password generator)
JWT_SECRET=super_secret_jwt_key_please_change
JWT_REFRESH_SECRET=super_secret_refresh_key_please_change
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 4. Database Configuration (REQUIRED)
# Set strong passwords for production databases
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_strong_password
POSTGRES_DB=ecomate_web
SEED_DUMMY_DATA=false

# 5. External API Integrations (Optional)
# If the client uses Meta/TikTok pixel, place them here
META_PIXEL_ID=
META_ACCESS_TOKEN=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=

# 6. Additional URLs (Usually dynamically set by CLIENT_DOMAIN, but can override)
CORS_ORIGIN=http://localhost:3000,https://${CLIENT_DOMAIN}
APP_URL=https://${CLIENT_DOMAIN}
STOREFRONT_URL=https://${CLIENT_DOMAIN}
ADMIN_VITE_API_URL=/api
STORE_NEXT_PUBLIC_API_URL=https://${CLIENT_DOMAIN}/api
STORE_NEXT_PUBLIC_STOREFRONT_URL=https://${CLIENT_DOMAIN}
