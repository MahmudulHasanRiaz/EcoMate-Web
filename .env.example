# ==========================================
# ECOMATE WEB — PORTAINER STACK ENVIRONMENT
# ==========================================
# Copy this file to .env and fill in the values before deploying.
# Fields marked with ⭐ are REQUIRED and must be changed.

# ─────────────────────────────────────────
# 1. DOMAIN (⭐ REQUIRED)
# ─────────────────────────────────────────
# Your client's domain. Do NOT include https://
CLIENT_DOMAIN=example.com

# ─────────────────────────────────────────
# 2. SSL / TRAEFIK (⭐ REQUIRED)
# ─────────────────────────────────────────
# Email used by Let's Encrypt to send certificate expiry notices
TRAEFIK_ACME_EMAIL=admin@example.com

# ─────────────────────────────────────────
# 3. SECURITY SECRETS (⭐ REQUIRED — MUST CHANGE)
# ─────────────────────────────────────────
# Generate with: openssl rand -hex 64
# JWT_SECRET and JWT_REFRESH_SECRET MUST be different from each other
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# 4. DATABASE (⭐ REQUIRED — change password)
# ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ecomate_web
# Set to true only on the FIRST deploy to seed initial data
SEED_DUMMY_DATA=false

# ─────────────────────────────────────────
# 4b. REDIS (Optional — falls back to memory)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────
# 5. PORT CONFIGURATION
# ─────────────────────────────────────────
# Change only if another service is already using these ports on the server.
# HTTP/HTTPS must stay at 80/443 for SSL to work (Let's Encrypt challenge).
HTTP_PORT=80
HTTPS_PORT=443

# ─────────────────────────────────────────
# 6. ADDITIONAL URLS (auto-resolved from CLIENT_DOMAIN)
# ─────────────────────────────────────────
# These are automatically built from CLIENT_DOMAIN in docker-compose.yml.
# Only override if you need a non-standard setup.
CORS_ORIGIN=https://${CLIENT_DOMAIN}
APP_URL=https://${CLIENT_DOMAIN}
STOREFRONT_URL=https://${CLIENT_DOMAIN}
ADMIN_VITE_API_URL=/api
STORE_NEXT_PUBLIC_API_URL=https://${CLIENT_DOMAIN}/api
STORE_NEXT_PUBLIC_STOREFRONT_URL=https://${CLIENT_DOMAIN}

# ─────────────────────────────────────────
# 7. TRACKING PIXELS (Optional)
# ─────────────────────────────────────────
# Can also be configured later from the Admin Panel → Settings → Tracking
META_PIXEL_ID=
META_ACCESS_TOKEN=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
