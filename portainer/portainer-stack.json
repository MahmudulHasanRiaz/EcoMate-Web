{
  "version": "2",
  "name": "ecomate",
  "description": "EcoMate E-Commerce Platform - Full Stack Deployment",
  "note": "Deploy via Portainer UI. Configure unique local ports if running multiple clients on the same server.",
  "repository": {
    "url": "https://github.com/your-org/ecomate-web",
    "stackfile": "docker-compose.yml"
  },
  "env": [
    { "name": "CLIENT_DOMAIN", "label": "⭐ Client Domain — e.g. example.com (NO https://)", "default": "" },
    { "name": "DOCKER_REGISTRY_OWNER", "label": "⭐ GitHub Username/Org (for Docker Registry images)", "default": "mahmudulhasanriaz" },

    { "name": "JWT_SECRET", "label": "⭐ JWT Secret (strong random string)", "default": "" },
    { "name": "JWT_REFRESH_SECRET", "label": "⭐ JWT Refresh Secret (different from JWT_SECRET)", "default": "" },

    { "name": "POSTGRES_PASSWORD", "label": "⭐ PostgreSQL Password (strong password)", "default": "" },
    { "name": "POSTGRES_USER", "label": "PostgreSQL User", "default": "postgres" },
    { "name": "POSTGRES_DB", "label": "PostgreSQL Database", "default": "ecomate_web" },

    { "name": "STOREFRONT_PORT", "label": "Storefront Host Port (localhost)", "default": "3000" },
    { "name": "BACKEND_PORT", "label": "Backend Host Port (localhost)", "default": "4000" },
    { "name": "ADMIN_PORT", "label": "Admin Host Port (localhost)", "default": "8080" },
    { "name": "POS_PORT", "label": "POS Host Port (localhost)", "default": "8081" },

    { "name": "CORS_ORIGIN", "label": "CORS Origins (auto-set from CLIENT_DOMAIN if left empty)", "default": "" },
    { "name": "APP_URL", "label": "App URL (auto-set from CLIENT_DOMAIN if left empty)", "default": "" },
    { "name": "STOREFRONT_URL", "label": "Storefront URL (auto-set from CLIENT_DOMAIN if left empty)", "default": "" },
    { "name": "STORE_NEXT_PUBLIC_API_URL", "label": "Storefront API URL (auto-set from CLIENT_DOMAIN if left empty)", "default": "" },
    { "name": "STORE_NEXT_PUBLIC_STOREFRONT_URL", "label": "Storefront Public URL (auto-set from CLIENT_DOMAIN if left empty)", "default": "" },
    { "name": "ADMIN_VITE_API_URL", "label": "Admin API URL", "default": "/api" },

    { "name": "SEED_DUMMY_DATA", "label": "Seed Dummy Data on first deploy? (true/false)", "default": "false" },
    { "name": "RUN_SEED", "label": "Run Seeding on startup? (true/false)", "default": "false" },

    { "name": "META_PIXEL_ID", "label": "Meta Pixel ID (Optional)", "default": "" },
    { "name": "META_ACCESS_TOKEN", "label": "Meta Access Token (Optional)", "default": "" },
    { "name": "TIKTOK_PIXEL_CODE", "label": "TikTok Pixel Code (Optional)", "default": "" },
    { "name": "TIKTOK_ACCESS_TOKEN", "label": "TikTok Access Token (Optional)", "default": "" },
    { "name": "GA_MEASUREMENT_ID", "label": "GA4 Measurement ID (Optional)", "default": "" },
    { "name": "GA_API_SECRET", "label": "GA4 API Secret (Optional)", "default": "" },
    { "name": "GA_ADS_CONVERSION_ID", "label": "Google Ads Conversion ID (Optional)", "default": "" },
    { "name": "GA_ADS_CONVERSION_LABEL", "label": "Google Ads Conversion Label (Optional)", "default": "" },
    { "name": "NEXT_PUBLIC_GA_MEASUREMENT_ID", "label": "GA4 Measurement ID (storefront, Optional)", "default": "" },
    { "name": "NEXT_PUBLIC_GA_ADS_CONVERSION_ID", "label": "Google Ads Conversion ID (storefront, Optional)", "default": "" }
  ]
}
