generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  inactive
  invited
  suspended
}

enum UserRole {
  superadmin
  admin
  cashier
  manager
  packing_assistant
  customer
}

enum TaskStatus {
  backlog
  todo
  in_progress @map("in progress")
  done
  canceled
}

enum TaskLabel {
  bug
  feature
  documentation
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum PaymentOptionType {
  FULL_PAYMENT
  PARTIAL_PAYMENT
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PAYMENT_PENDING
  PENDING
  PAID
  PARTIAL_PAID
  UNPAID
  FAILED
  CANCELLED
  REFUNDED
}

enum WarehouseType {
  main
  showroom
  storage
}

enum OrderSource {
  POS
  ECOMMERCE
  MANUAL
}

enum SalesChannel {
  CALL
  FACEBOOK
  INSTAGRAM
  TIKTOK
  MESSENGER
  WHATSAPP
  THREADS
  WALK_IN
  WEBSITE
  OTHER
}

model User {
  id                  String     @id @default(uuid())
  firstName           String
  lastName            String
  username            String     @unique
  email               String     @unique
  phoneNumber         String
  password            String
  emailVerified       Boolean    @default(false)
  failedLoginAttempts Int        @default(0)
  lockoutUntil        DateTime?
  status              UserStatus @default(active)
  role                UserRole   @default(admin)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  tasks          Task[]
  settings       UserSettings?
  refreshTokens  RefreshToken[]
  orders         Order[]
  addresses      Address[]
  assignedOrders Order[]        @relation("OrderAssignee")
  payments       Payment[]      @relation("VerifiedPayments")
  refunds        Refund[]       @relation("RefundProcessor")
  assignedLeads  CheckoutLead[] @relation("CheckoutLeadAssignedTo")
  assignedByMe   CheckoutLead[] @relation("CheckoutLeadAssignedBy")
  convertedLeads CheckoutLead[] @relation("CheckoutLeadConvertedBy")
  referrals     Referral[]
  posSessions   PosSession[]
  heldCarts     HeldCart[]

  @@index([role])
  @@index([status])
  @@index([phoneNumber])
}

model VerificationToken {
  id        String    @id @default(uuid())
  email     String
  token     String
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, type])
  @@index([token, type])
}

model Task {
  id          String       @id @default(uuid())
  displayId   String       @unique
  title       String
  status      TaskStatus   @default(todo)
  label       TaskLabel    @default(feature)
  priority    TaskPriority @default(medium)
  assignee    String?
  description String?
  dueDate     DateTime?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([assignee])
  @@index([status])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique

  theme                          String   @default("light")
  font                           String   @default("inter")
  username                       String?
  email                          String?
  bio                            String?
  urls                           String?
  accountName                    String?
  accountDob                     String?
  accountLanguage                String?
  notificationType               String   @default("all")
  notificationMobile             Boolean  @default(false)
  notificationCommunicationEmail Boolean  @default(false)
  notificationSocialEmail        Boolean  @default(false)
  notificationMarketingEmail     Boolean  @default(false)
  notificationSecurityEmail      Boolean  @default(true)
  displayItems                   String?
  autoVariantSelect              Boolean  @default(true)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  label       String // "Home", "Office", etc.
  fullName    String
  phoneNumber String
  street      String
  city        String
  state       String?
  zipCode     String?
  country     String   @default("Bangladesh")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  parentId      String?
  image         String?
  sortOrder     Int      @default(0)
  showInMenu    Boolean  @default(true)
  menuSortOrder Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent            Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]        @relation("CategoryTree")
  products          Product[]         @relation("ProductCategory")
  productCategories ProductCategory[]
  combos            Combo[]
  sizeChartId       String?
  sizeChart         SizeChart?        @relation(fields: [sizeChartId], references: [id], onDelete: SetNull)
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[] @relation("ProductBrand")
}

model Attribute {
  id        String           @id @default(uuid())
  name      String           @unique
  values    AttributeValue[]
  createdAt DateTime         @default(now())
}

model AttributeValue {
  id          String @id @default(uuid())
  value       String
  attributeId String
  sortOrder   Int    @default(0)

  attribute Attribute                      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants  ProductVariantAttributeValue[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  type        String   @default("simple")
  description String?  @db.Text
  shortDesc   String?  @db.Text
  basePrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @db.Decimal(10, 2)
  sku         String?
  stock       Int      @default(0)
  lowStockQty Int?
  categoryId  String?
  tags        Json?    @default("[]")
  images      Json?    @default("[]")
  seoMeta     Json?    @default("{}")
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  manageStock Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brandId                String?
  brand                  Brand?                 @relation("ProductBrand", fields: [brandId], references: [id], onDelete: SetNull)
  reservedStock          Int                    @default(0)
  warehouseId            String?
  defaultBinLocationId   String?
  warehouse              Warehouse?             @relation(fields: [warehouseId], references: [id])
  category               Category?              @relation("ProductCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  productCategories      ProductCategory[]
  productTags            ProductTag[]
  variants               ProductVariant[]
  orderItems             OrderItem[]
  comboItems             ComboItem[]
  sizeChartId            String?
  sizeChart              SizeChart?             @relation(fields: [sizeChartId], references: [id], onDelete: SetNull)
  reviews                Review[]
  paymentOptionOverrides ProductPaymentOption[]
  purchaseItems          PurchaseItem[]

  @@index([isActive])
  @@index([categoryId])
  @@index([createdAt])
  @@index([sku])
  @@index([type])
  @@index([brandId])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sku       String   @unique
  price     Decimal? @db.Decimal(10, 2)
  salePrice Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues ProductVariantAttributeValue[]
  orderItems      OrderItem[]
  comboItems      ComboItem[]
  purchaseItems   PurchaseItem[]
  reservedStock   Int                            @default(0)
  warehouseId     String?
  binLocationId   String?
  warehouse       Warehouse?                     @relation(fields: [warehouseId], references: [id])

  @@index([productId])
}

model ProductVariantAttributeValue {
  id               String @id @default(uuid())
  variantId        String
  attributeValueId String

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
}

model Combo {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  shortDesc   String?   @db.Text
  basePrice   Decimal   @db.Decimal(10, 2)
  salePrice   Decimal?  @db.Decimal(10, 2)
  image       String?
  images      Json?     @default("[]")
  categoryId  String?
  tags        Json?     @default("[]")
  seoMeta     Json?     @default("{}")
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  manageStock Boolean   @default(false)
  stock       Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category               Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items                  ComboItem[]
  orderItems             OrderItem[]
  paymentOptionOverrides ProductPaymentOption[]
  reservedStock          Int                    @default(0)
  warehouseId            String?
  warehouse              Warehouse?             @relation(fields: [warehouseId], references: [id])

  @@index([isActive])
}

model ComboItem {
  id        String   @id @default(uuid())
  comboId   String
  productId String
  variantId String?
  quantity  Int      @default(1)
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  combo   Combo           @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([comboId, productId, variantId])
}

enum PosSessionStatus {
  open
  closed
  cancelled
}

model PosSession {
  id              String           @id @default(uuid())
  showroomId      String
  showroom        Warehouse        @relation(fields: [showroomId], references: [id])
  cashierId       String
  cashier         User             @relation(fields: [cashierId], references: [id])
  openingBalance  Decimal          @db.Decimal(10, 2)
  closingBalance  Decimal?         @db.Decimal(10, 2)
  expectedBalance Decimal?         @db.Decimal(10, 2)
  status          PosSessionStatus @default(open)
  openedAt        DateTime         @default(now())
  closedAt        DateTime?
  notes           String?
  orders          Order[]
  heldCarts       HeldCart[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([showroomId])
  @@index([cashierId])
  @@index([status])
}

model HeldCart {
  id           String   @id @default(uuid())
  sessionId    String
  cashierId    String
  items        Json
  customerId   String?
  guestName    String?
  guestPhone   String?
  discount     Decimal  @default(0) @db.Decimal(10, 2)
  discountType String   @default("flat")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session   PosSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cashier   User       @relation(fields: [cashierId], references: [id])

  @@index([sessionId])
  @@index([cashierId])
}

model OrderStatus {
  id           String   @id @default(uuid())
  name         String   @unique
  color        String   @default("#6B7280")
  nextStatuses Json?    @default("[]")
  isInitial    Boolean  @default(false)
  isFinal      Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Order {
  id                       String             @id @default(uuid())
  displayId                String             @unique
  customerId               String?
  statusId                 String
  subtotal                 Decimal            @db.Decimal(10, 2)
  shippingCharge           Decimal            @default(0) @db.Decimal(10, 2)
  discount                 Decimal            @default(0) @db.Decimal(10, 2)
  discountType             String             @default("flat")
  total                    Decimal            @db.Decimal(10, 2)
  shippingAddress          Json?              @default("{}")
  customerNotes            String?
  officeNotes              String?
  courierService           CourierService?
  courierConsignmentId     String?
  courierTrackingCode      String?
  courierStatus            String?
  assignedToId             String?
  assignedAt               DateTime?
  timeline                 Json?              @default("[]")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  guestName                String?
  guestPhone               String?
  paymentOptionType        PaymentOptionType? // FULL_PAYMENT | PARTIAL_PAYMENT | CASH_ON_DELIVERY
  paymentOption            PaymentOption?     @relation(fields: [paymentOptionType], references: [type])
  source                   OrderSource?       @default(ECOMMERCE)
  salesChannel             SalesChannel?
  posSessionId             String?
  posSession               PosSession?        @relation(fields: [posSessionId], references: [id])
  paymentStatus            PaymentStatus      @default(PAYMENT_PENDING)
  partialAmount            Decimal?           @db.Decimal(10, 2)
  viewToken                String?            @unique
  selectedShippingOptionId String?
  shippingChargeOverridden Boolean            @default(false)

  customer     User?                @relation(fields: [customerId], references: [id])
  assignee     User?                @relation("OrderAssignee", fields: [assignedToId], references: [id])
  status       OrderStatus          @relation(fields: [statusId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  shipment     Shipment?
  dispatchLogs CourierDispatchLog[]
  refunds      Refund[]
  couponUsages CouponUsage[]
  referralLeads ReferralLead[]

  @@index([customerId])
  @@index([statusId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([courierService])
  @@index([courierConsignmentId])
  @@index([courierTrackingCode])
  @@index([paymentOptionType])
  @@index([guestPhone])
  @@index([posSessionId])
  @@index([source])
  @@index([salesChannel])
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  productId      String?
  variantId      String?
  comboId        String?
  comboSelection Json?
  quantity       Int      @default(1)
  price          Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  combo       Combo?          @relation(fields: [comboId], references: [id])
  costingLotId String?
  costingLot  CostingLot?     @relation(fields: [costingLotId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([comboId])
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  gatewayCode   String // Links to PaymentGateway.code (e.g., 'bkash', 'nagad', 'bkash_pgw', 'cash')
  amount        Decimal       @db.Decimal(10, 2)
  transactionId String?
  screenshot    String?
  status        PaymentStatus @default(PENDING)
  verifiedBy    String?
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifier User? @relation("VerifiedPayments", fields: [verifiedBy], references: [id])

  @@index([orderId])
  @@index([gatewayCode])
  @@index([transactionId])
}

model CheckoutLead {
  id               String    @id @default(uuid())
  displayId        String?   @unique
  phone            String?
  name             String?
  email            String?
  address          Json?
  items            Json?
  payload          Json?
  paymentMethod    String?
  status           String    @default("PENDING")
  fingerprint      String?
  occurrences      Int       @default(1)
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  assignedToId     String?
  assignedById     String?
  assignedAt       DateTime?
  convertedAt      DateTime?
  convertedById    String?
  convertedOrderId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedTo  User? @relation("CheckoutLeadAssignedTo", fields: [assignedToId], references: [id])
  assignedBy  User? @relation("CheckoutLeadAssignedBy", fields: [assignedById], references: [id])
  convertedBy User? @relation("CheckoutLeadConvertedBy", fields: [convertedById], references: [id])

  @@index([phone])
  @@index([status])
  @@index([assignedToId])
  @@index([lastSeenAt])
  @@index([fingerprint])
}

model Shipment {
  id         String   @id @default(uuid())
  orderId    String   @unique
  trackingNo String?
  courier    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ShippingOption {
  id        String   @id @default(uuid())
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingZoneGroup {
  id        String   @id @default(uuid())
  label     String?
  type      String
  amount    Decimal? @db.Decimal(10, 2)
  districts Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  variables Json?    @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns EmailCampaign[]
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  cancelled
}

model EmailCampaign {
  id            String         @id @default(uuid())
  name          String
  subject       String
  templateId    String?
  content       String?        @db.Text
  recipients    Json?          @default("[]")
  segmentFilter Json?          @default("{}")
  scheduledAt   DateTime?
  sentAt        DateTime?
  status        CampaignStatus @default(draft)
  totalSent     Int            @default(0)
  totalFailed   Int            @default(0)
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model PaymentOption {
  id          String            @id @default(uuid())
  type        PaymentOptionType @unique
  name        String
  description String?
  enabled     Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  gateways         PaymentGateway[]
  productOverrides ProductPaymentOption[]
  orders           Order[]
}

model PaymentGateway {
  id                String            @id @default(uuid())
  code              String            @unique
  name              String
  type              String // 'manual' | 'api' | 'cash'
  paymentOptionType PaymentOptionType
  paymentOption     PaymentOption     @relation(fields: [paymentOptionType], references: [type])
  enabled           Boolean           @default(false)
  mode              String            @default("personal") // 'personal' | 'agent' | 'merchant' | 'sandbox' | 'production'
  phoneNumber       String?
  credentials       Json?             @default("{}")
  sortOrder         Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([paymentOptionType])
}

model ProductPaymentOption {
  id                 String            @id @default(uuid())
  productId          String?
  comboId            String?
  paymentOptionType  PaymentOptionType
  paymentOption      PaymentOption     @relation(fields: [paymentOptionType], references: [type])
  enabled            Boolean           @default(true)
  partialFixedAmount Decimal?          @db.Decimal(10, 2) // Fixed amount for partial payment
  partialPercentage  Decimal?          @db.Decimal(5, 2) // Percentage for partial payment (e.g., 30.00 for 30%)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  combo   Combo?   @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@unique([productId, comboId, paymentOptionType])
  @@index([productId])
  @@index([comboId])
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  mimeType   String
  size       Int
  hash       String?
  alt        String?
  width      Int?
  height     Int?
  sourceUrl  String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  attachments MediaAttachment[]

  @@index([hash])
  @@index([url])
}

model MediaAttachment {
  id         String   @id @default(uuid())
  mediaId    String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entityType, entityId])
  @@index([entityType, entityId])
}

enum CourierService {
  steadfast
  pathao
  redx
  carrybee
}

model CourierCredentials {
  id            String   @id @default(uuid())
  courier       String   @unique
  enabled       Boolean  @default(false)
  mode          String   @default("sandbox")
  apiKey        String?
  secretKey     String?
  username      String?
  password      String?
  clientId      String?
  clientSecret  String?
  storeId       String?
  webhookSecret String?
  credentials   Json?    @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CourierDispatchLog {
  id              String   @id @default(uuid())
  orderId         String
  courier         String
  status          String
  message         String?
  requestPayload  Json?
  responsePayload Json?
  consignmentId   String?
  trackingCode    String?
  createdAt       DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([courier])
}

model Coupon {
  id                 String    @id @default(uuid())
  code               String    @unique
  type               String    @default("flat")
  value              Decimal   @db.Decimal(10, 2)
  minOrderValue      Decimal?  @db.Decimal(10, 2)
  maxUses            Int?
  usedCount          Int       @default(0)
  maxUsesPerCustomer Int?
  percentageCap      Decimal?  @db.Decimal(5, 2)
  startsAt           DateTime?
  expiresAt          DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  usages CouponUsage[]
}

model CouponUsage {
  id       String   @id @default(uuid())
  couponId String
  orderId  String
  userId   String?
  discount Decimal  @db.Decimal(10, 2)
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([orderId])
  @@index([userId])
}

model Refund {
  id          String    @id @default(uuid())
  orderId     String
  amount      Decimal   @db.Decimal(10, 2)
  reason      String?
  status      String    @default("pending")
  processedBy String?
  processedAt DateTime?
  notes           String? @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processor User? @relation("RefundProcessor", fields: [processedBy], references: [id])

  @@index([orderId])
}

model InventoryLog {
  id          String   @id @default(uuid())
  productId   String?
  variantId   String?
  comboId     String?
  quantity    Int
  type        String
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([productId, variantId, createdAt])
}

model OrderCounter {
  date String @id // YYMMDD
  seq  Int
}

model Review {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName String
  rating       Int
  text         String?  @db.Text
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("reviews")
}

model SizeChart {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  image       String?
  tableData   Json?    @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[]
  products   Product[]
}

model CmsPage {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  content      String   @db.Text
  isActive     Boolean  @default(true)
  showInFooter Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, showInFooter])
}

model BlockedIp {
  id          String    @id @default(uuid())
  ip          String    @unique
  blockType   String    @default("order")
  reason      String?
  blockedAt   DateTime  @default(now())
  blockedBy   String?
  isActive    Boolean   @default(true)
  whitelisted Boolean   @default(false)
  autoBlocked Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([blockType, isActive, whitelisted])
  @@index([isActive, autoBlocked])
  @@index([isActive, expiresAt])
}

model BlockedPhone {
  id          String    @id @default(uuid())
  phone       String    @unique
  reason      String?
  blockedAt   DateTime  @default(now())
  blockedBy   String?
  isActive    Boolean   @default(true)
  whitelisted Boolean   @default(false)
  autoBlocked Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([phone])
  @@index([phone, isActive, whitelisted])
  @@index([isActive])
  @@index([isActive, autoBlocked])
  @@index([isActive, expiresAt])
}

model BlockSettings {
  id   String @id @default("singleton")
  data Json
}

model Tag {
  id           String       @id @default(uuid())
  name         String       @unique
  slug         String       @unique
  productCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  products     ProductTag[]
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model LandingPage {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  pageType     String    @default("template")
  templateId   String?
  sections     Json?     @default("[]")
  customHtml   String?   @db.Text
  customCss    String?   @db.Text
  productIds   Json?     @default("[]")
  comboIds     Json?     @default("[]")
  trackingJson Json?     @default("{}")
  isActive     Boolean   @default(false)
  isDraft      Boolean   @default(true)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum PurchaseStatus {
  draft
  ordered
  partially_received
  received
  cancelled
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  icon        String?
  color       String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id])
  expenses    Expense[]

  @@index([accountId])
  @@map("expense_categories")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String   @default("Bangladesh")
  taxId         String?
  paymentTerms  String?
  notes         String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  totalPurchases Decimal          @default(0) @db.Decimal(14, 2)
  totalPaid      Decimal          @default(0) @db.Decimal(14, 2)
  balance        Decimal          @default(0) @db.Decimal(14, 2)
  purchases      Purchase[]
  payments       SupplierPayment[]

  @@index([isActive])
}

model Purchase {
  id           String         @id @default(uuid())
  supplierId   String
  referenceNo  String         @unique
  orderDate    DateTime       @default(now())
  expectedDate DateTime?
  status       PurchaseStatus @default(draft)
  subtotal     Decimal        @db.Decimal(12, 2)
  taxAmount    Decimal        @default(0) @db.Decimal(12, 2)
  discount     Decimal        @default(0) @db.Decimal(12, 2)
  total        Decimal        @db.Decimal(12, 2)
  paidAmount   Decimal        @default(0) @db.Decimal(12, 2)
  notes        String?        @db.Text
  createdBy    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  supplier    Supplier             @relation(fields: [supplierId], references: [id])
  items       PurchaseItem[]
  costingLots CostingLot[]
  grns        GoodsReceiptNote[]

  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id          String          @id @default(uuid())
  purchaseId  String
  productId   String?
  variantId   String?
  description String?
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalPrice  Decimal         @db.Decimal(12, 2)
  totalBill   Decimal         @db.Decimal(14, 2)
  receivedQty Int             @default(0)

  purchase Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
}

model Expense {
  id              String          @id @default(uuid())
  description     String
  categoryId      String
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount          Decimal         @db.Decimal(10, 2)
  taxAmount       Decimal         @default(0) @db.Decimal(10, 2)
  expenseDate     DateTime
  paymentMethod   String?         // kept for backward compat (pre-accounting)
  paymentAccountId String?
  paymentAccount  Account?  @relation(fields: [paymentAccountId], references: [id])
  journalEntryId  String?         @unique
  journalEntry    JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  referenceNo     String?
  notes           String?         @db.Text
  receiptUrl      String?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([categoryId])
  @@index([paymentAccountId])
  @@index([expenseDate])
  @@index([createdAt])
}

model NotificationSetting {
  id        String   @id @default(uuid())
  channel   String
  type      String
  enabled   Boolean  @default(true)
  config    Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, type])
}

model NotificationLog {
  id        String   @id @default(uuid())
  channel   String
  eventType String
  recipient String
  subject   String?
  content   String?  @db.Text
  status    String   @default("sent")
  error     String?
  metadata  Json?    @default("{}")
  sentAt    DateTime @default(now())

  @@index([channel, status])
  @@index([recipient])
  @@index([sentAt])
}

model Referral {
  id            String    @id @default(uuid())
  code          String    @unique
  referrerId    String
  totalReferrals Int      @default(0)
  totalReward   Decimal   @default(0) @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referrer User       @relation(fields: [referrerId], references: [id])
  leads    ReferralLead[]
  rewards  ReferralReward[]

  @@index([referrerId])
  @@index([code])
}

model ReferralLead {
  id         String    @id @default(uuid())
  referralId String
  phone      String
  name       String?
  status     String    @default("pending")
  orderId    String?
  rewardAmount Decimal? @db.Decimal(10, 2)
  rewardGiven Boolean  @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([referralId])
  @@index([phone])
  @@index([status])
}

model ReferralReward {
  id          String   @id @default(uuid())
  referralId  String
  type        String   @default("coupon")
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  givenAt     DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([referralId])
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
}

enum EmployeeStatus {
  active
  inactive
  terminated
  resigned
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employees Employee[]
}

model Designation {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  level     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  employees Employee[]
}

model Employee {
  id               String          @id @default(uuid())
  userId           String?
  employeeId       String          @unique
  firstName        String
  lastName         String
  email            String          @unique
  phone            String?
  departmentId     String?
  designationId    String?
  employmentType   EmploymentType  @default(full_time)
  status           EmployeeStatus  @default(active)
  joiningDate      DateTime
  exitDate         DateTime?
  salary           Decimal?        @db.Decimal(10, 2)
  bankAccountNo    String?
  bankName         String?
  address          String?
  city             String?
  emergencyContact String?
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  salaryStructures SalaryStructure[]
  payslips         Payslip[]

  @@index([departmentId])
  @@index([designationId])
  @@index([status])
}

enum PayslipStatus {
  draft
  approved
  paid
  cancelled
}

model SalaryStructure {
  id                String   @id @default(uuid())
  employeeId        String
  basicSalary       Decimal  @db.Decimal(10, 2)
  houseAllowance    Decimal  @default(0) @db.Decimal(10, 2)
  medicalAllowance  Decimal  @default(0) @db.Decimal(10, 2)
  transportAllowance Decimal @default(0) @db.Decimal(10, 2)
  otherAllowance    Decimal  @default(0) @db.Decimal(10, 2)
  taxDeduction      Decimal  @default(0) @db.Decimal(10, 2)
  insuranceDeduction Decimal @default(0) @db.Decimal(10, 2)
  otherDeduction    Decimal  @default(0) @db.Decimal(10, 2)
  totalEarnings     Decimal  @db.Decimal(10, 2)
  totalDeductions   Decimal  @default(0) @db.Decimal(10, 2)
  netSalary         Decimal  @db.Decimal(10, 2)
  effectiveFrom     DateTime @default(now())
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Payslip {
  id              String        @id @default(uuid())
  employeeId      String
  periodStart     DateTime
  periodEnd       DateTime
  totalEarnings   Decimal       @db.Decimal(10, 2)
  totalDeductions Decimal       @default(0) @db.Decimal(10, 2)
  netPay          Decimal       @db.Decimal(10, 2)
  status          PayslipStatus @default(draft)
  generatedAt     DateTime      @default(now())
  paidAt          DateTime?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee Employee  @relation(fields: [employeeId], references: [id])
  items    PayslipItem[]

  @@index([employeeId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model PayslipItem {
  id        String  @id @default(uuid())
  payslipId String
  type      String
  label     String
  amount    Decimal @db.Decimal(10, 2)

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId])
}

enum AccountType {
  asset
  liability
  equity
  income
  expense
}

model Account {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  type        AccountType
  parentId    String?
  description String?     @db.Text
  isActive    Boolean     @default(true)
  isGroup     Boolean     @default(false)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  parent          Account?             @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]            @relation("AccountHierarchy")
  openingBalances OpeningBalance[]
  journalLines    JournalEntryLine[]
  expenseCategory ExpenseCategory[]
  expensePayments Expense[]

  @@index([type])
  @@index([parentId])
}

model FinancialPeriod {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openingBalances OpeningBalance[]
  journalEntries  JournalEntry[]

  @@unique([startDate, endDate])
}

model OpeningBalance {
  id        String   @id @default(uuid())
  accountId String
  periodId  String
  debit     Decimal  @default(0) @db.Decimal(14, 2)
  credit    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account          @relation(fields: [accountId], references: [id])
  period  FinancialPeriod  @relation(fields: [periodId], references: [id])

  @@unique([accountId, periodId])
  @@index([periodId])
}

model JournalEntry {
  id          String       @id @default(uuid())
  entryNo     String       @unique
  periodId    String
  entryDate   DateTime
  description String
  totalDebit  Decimal      @db.Decimal(14, 2)
  totalCredit Decimal      @db.Decimal(14, 2)
  isOpening   Boolean      @default(false)
  referenceNo String?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  period FinancialPeriod @relation(fields: [periodId], references: [id])
  lines  JournalEntryLine[]
  expense Expense?

  @@index([periodId])
  @@index([entryDate])
}

model JournalEntryLine {
  id          String       @id @default(uuid())
  entryId     String
  accountId   String
  debit       Decimal      @default(0) @db.Decimal(14, 2)
  credit      Decimal      @default(0) @db.Decimal(14, 2)
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

model Warehouse {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  type      WarehouseType    @default(main)
  address   String?
  city      String?
  country   String           @default("Bangladesh")
  phone     String?
  email     String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  products     Product[]
  variants     ProductVariant[]
  combos       Combo[]
  binLocations BinLocation[]
  posSessions  PosSession[]

  @@index([isActive])
}

model BinLocation {
  id          String    @id @default(uuid())
  warehouseId String
  code        String
  zone        String?
  rack        String?
  shelf       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model CostingLot {
  id           String             @id @default(uuid())
  purchaseId   String?
  grnId        String?
  productId    String
  variantId    String?
  lotNumber    String             @unique
  unitCost     Decimal            @db.Decimal(12, 2)
  totalCost    Decimal            @db.Decimal(14, 2)
  quantity     Int
  remainingQty Int
  receivedAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())

  purchase Purchase?         @relation(fields: [purchaseId], references: [id])
  grn      GoodsReceiptNote? @relation(fields: [grnId], references: [id])
  orderItems OrderItem[]

  @@index([productId, remainingQty])
  @@index([purchaseId])
}

model GoodsReceiptNote {
  id         String   @id @default(uuid())
  grnNumber  String   @unique
  purchaseId String
  receivedBy String?
  receivedAt DateTime @default(now())
  status     String   @default("draft")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  purchase    Purchase               @relation(fields: [purchaseId], references: [id])
  items       GoodsReceiptNoteItem[]
  costingLots CostingLot[]
}

model GoodsReceiptNoteItem {
  id             String  @id @default(uuid())
  grnId          String
  purchaseItemId String?
  productId      String
  variantId      String?
  expectedQty    Int
  receivedQty    Int
  acceptedQty    Int
  rejectedQty    Int     @default(0)
  unitCost       Decimal @db.Decimal(12, 2)
  totalCost      Decimal @db.Decimal(14, 2)

  grn GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
}

model SupplierPayment {
  id            String   @id @default(uuid())
  supplierId    String
  amount        Decimal  @db.Decimal(14, 2)
  paidAt        DateTime @default(now())
  paymentMethod String?
  reference     String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  supplier Supplier                @relation(fields: [supplierId], references: [id])
  invoices  SupplierPaymentInvoice[]

  @@index([supplierId])
}

model SupplierPaymentInvoice {
  id        String  @id @default(uuid())
  paymentId String
  invoiceNo String  @unique

  payment SupplierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model LicenseActivation {
  id            String    @id @default(uuid())
  licenseKey    String
  keymateUrl    String
  domain        String?
  apiKey        String?
  licenseInfo   Json?     @db.JsonB
  status        String    @default("pending")
  errorMessage  String?
  activatedAt   DateTime?
  expiresAt     DateTime?
  lastCheckIn   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
