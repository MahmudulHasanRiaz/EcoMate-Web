generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  invited
  suspended
}

enum UserRole {
  superadmin
  admin
  cashier
  manager
  customer
}

enum TaskStatus {
  backlog
  todo
  in_progress @map("in progress")
  done
  canceled
}

enum TaskLabel {
  bug
  feature
  documentation
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model User {
  id          String     @id @default(uuid())
  firstName   String
  lastName    String
  username    String     @unique
  email       String     @unique
  phoneNumber String
  password    String
  status      UserStatus @default(active)
  role        UserRole   @default(admin)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks         Task[]
  settings      UserSettings?
  refreshTokens RefreshToken[]
  orders        Order[]
  assignedOrders Order[]      @relation("OrderAssignee")
  payments      Payment[]     @relation("VerifiedPayments")
  refunds       Refund[]      @relation("RefundProcessor")
  assignedLeads    CheckoutLead[] @relation("CheckoutLeadAssignedTo")
  assignedByMe     CheckoutLead[] @relation("CheckoutLeadAssignedBy")
  convertedLeads   CheckoutLead[] @relation("CheckoutLeadConvertedBy")
}

model Task {
  id          String       @id @default(uuid())
  displayId   String       @unique
  title       String
  status      TaskStatus   @default(todo)
  label       TaskLabel    @default(feature)
  priority    TaskPriority @default(medium)
  assignee    String?
  description String?
  dueDate     DateTime?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique

  theme                          String  @default("light")
  font                           String  @default("inter")
  username                       String?
  email                          String?
  bio                            String?
  urls                           String?
  accountName                    String?
  accountDob                     String?
  accountLanguage                String?
  notificationType               String  @default("all")
  notificationMobile             Boolean @default(false)
  notificationCommunicationEmail Boolean @default(false)
  notificationSocialEmail        Boolean @default(false)
  notificationMarketingEmail     Boolean @default(false)
  notificationSecurityEmail      Boolean @default(true)
  displayItems                   String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  parentId  String?
  image     String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]
  combos   Combo[]
}

model Attribute {
  id        String           @id @default(uuid())
  name      String           @unique
  values    AttributeValue[]
  createdAt DateTime         @default(now())
}

model AttributeValue {
  id          String                       @id @default(uuid())
  value       String
  attributeId String
  sortOrder   Int                          @default(0)

  attribute   Attribute                     @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants    ProductVariantAttributeValue[]
}

model Product {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  type        String    @default("simple")
  description String?   @db.Text
  shortDesc   String?   @db.Text
  basePrice   Decimal   @db.Decimal(10, 2)
  salePrice   Decimal?  @db.Decimal(10, 2)
  sku         String?
  stock       Int       @default(0)
  lowStockQty Int?
  categoryId  String?
  tags        Json?     @default("[]")
  images      Json?     @default("[]")
  seoMeta     Json?     @default("{}")
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  manageStock Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category   Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  orderItems OrderItem[]
  comboItems ComboItem[]
}

model ProductVariant {
  id        String    @id @default(uuid())
  productId String
  sku       String    @unique
  price     Decimal?  @db.Decimal(10, 2)
  stock     Int       @default(0)
  image     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  product         Product                          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues ProductVariantAttributeValue[]
  orderItems      OrderItem[]
  comboItems      ComboItem[]
}

model ProductVariantAttributeValue {
  id               String          @id @default(uuid())
  variantId        String
  attributeValueId String

  variant         ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue  AttributeValue  @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
}

model Combo {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  shortDesc   String?   @db.Text
  basePrice   Decimal   @db.Decimal(10, 2)
  salePrice   Decimal?  @db.Decimal(10, 2)
  image       String?
  images      Json?     @default("[]")
  categoryId  String?
  tags        Json?     @default("[]")
  seoMeta     Json?     @default("{}")
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  manageStock Boolean   @default(false)
  stock       Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category   Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items      ComboItem[]
  orderItems OrderItem[]
}

model ComboItem {
  id        String    @id @default(uuid())
  comboId   String
  productId String
  variantId String?
  quantity  Int       @default(1)
  price     Decimal?  @db.Decimal(10, 2)
  createdAt DateTime  @default(now())

  combo   Combo           @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([comboId, productId, variantId])
}

model OrderStatus {
  id           String   @id @default(uuid())
  name         String   @unique
  color        String   @default("#6B7280")
  nextStatuses Json?    @default("[]")
  isInitial    Boolean  @default(false)
  isFinal      Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Order {
  id              String    @id @default(uuid())
  displayId       String    @unique
  customerId      String?
  statusId        String
  subtotal        Decimal   @db.Decimal(10, 2)
  shippingCharge  Decimal   @default(0) @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  discountType    String    @default("flat")
  total           Decimal   @db.Decimal(10, 2)
  shippingAddress Json?     @default("{}")
  customerNotes   String?
  officeNotes     String?
  courierService  CourierService?
  courierConsignmentId String?
  courierTrackingCode  String?
  courierStatus   String?
  assignedToId    String?
  assignedAt      DateTime?
  timeline        Json?     @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  guestName       String?
  guestPhone      String?
  paymentMethod   String?

  customer User?       @relation(fields: [customerId], references: [id])
  assignee User?        @relation("OrderAssignee", fields: [assignedToId], references: [id])
  status   OrderStatus @relation(fields: [statusId], references: [id])
  items    OrderItem[]
  payments Payment[]
  shipment Shipment?
  dispatchLogs CourierDispatchLog[]
  refunds    Refund[]
}

model OrderItem {
  id        String    @id @default(uuid())
  orderId   String
  productId String?
  variantId String?
  comboId   String?
  quantity  Int       @default(1)
  price     Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?         @relation(fields: [productId], references: [id])
  variant ProductVariant?  @relation(fields: [variantId], references: [id])
  combo   Combo?           @relation(fields: [comboId], references: [id])
}

model Payment {
  id            String    @id @default(uuid())
  orderId       String
  method        String
  amount        Decimal   @db.Decimal(10, 2)
  transactionId String?
  screenshot    String?
  status        String    @default("pending")
  verifiedBy    String?
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifier User?  @relation("VerifiedPayments", fields: [verifiedBy], references: [id])
}

model CheckoutLead {
  id              String    @id @default(uuid())
  phone           String?
  name            String?
  email           String?
  address         Json?
  items           Json?
  payload         Json?
  paymentMethod   String?
  status          String    @default("PENDING")
  fingerprint     String?
  occurrences     Int       @default(1)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  assignedToId    String?
  assignedById    String?
  assignedAt      DateTime?
  convertedAt     DateTime?
  convertedById   String?
  convertedOrderId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedTo      User?  @relation("CheckoutLeadAssignedTo", fields: [assignedToId], references: [id])
  assignedBy      User?  @relation("CheckoutLeadAssignedBy", fields: [assignedById], references: [id])
  convertedBy     User?  @relation("CheckoutLeadConvertedBy", fields: [convertedById], references: [id])

  @@index([phone])
  @@index([status])
  @@index([assignedToId])
  @@index([lastSeenAt])
}

model Shipment {
  id         String    @id @default(uuid())
  orderId    String    @unique
  trackingNo String?
  courier    String?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model PaymentGatewayConfig {
  id          String   @id @default(uuid())
  gateway     String   @unique
  enabled     Boolean  @default(false)
  mode        String   @default("personal")
  phoneNumber String?
  credentials Json?     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  mimeType   String
  size       Int
  uploadedBy String?
  createdAt  DateTime @default(now())

  attachments MediaAttachment[]
}

model MediaAttachment {
  id         String   @id @default(uuid())
  mediaId    String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entityType, entityId])
}

enum CourierService {
  steadfast
  pathao
  redx
  carrybee
}

model CourierCredentials {
  id             String   @id @default(uuid())
  courier        String   @unique
  enabled        Boolean  @default(false)
  mode           String   @default("sandbox")
  apiKey         String?
  secretKey      String?
  username       String?
  password       String?
  clientId       String?
  clientSecret   String?
  storeId        String?
  webhookSecret  String?
  credentials    Json?    @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CourierDispatchLog {
  id              String   @id @default(uuid())
  orderId         String
  courier         String
  status          String
  message         String?
  requestPayload  Json?
  responsePayload Json?
  consignmentId   String?
  trackingCode    String?
  createdAt       DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  type          String    @default("flat")
  value         Decimal   @db.Decimal(10, 2)
  minOrderValue Decimal?  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Refund {
  id          String    @id @default(uuid())
  orderId     String
  amount      Decimal   @db.Decimal(10, 2)
  reason      String?
  status      String    @default("pending")
  processedBy String?
  processedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processor User? @relation("RefundProcessor", fields: [processedBy], references: [id])
}

model InventoryLog {
  id          String   @id @default(uuid())
  productId   String?
  variantId   String?
  comboId     String?
  quantity    Int
  type        String
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())
}
